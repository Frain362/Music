<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        xmlns:converters="clr-namespace:WpfApp1.Converters"
        mc:Ignorable="d"
        Title="VibeBox - Музыкальный плеер" Height="550" Width="750"
        AllowDrop="True"
        Drop="Window_Drop"
        Background="#1A1A1A"
        Foreground="#FFFFFF" ResizeMode="NoResize">

    <Window.Resources>
        <!-- Конвертер для кнопки Play/Pause -->
        <converters:PlayPauseConverter x:Key="PlayPauseConverter"/>

        <SolidColorBrush x:Key="AccentColor" Color="#FF6B6B"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок управления (круглые) -->
        <Style x:Key="ControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{StaticResource AccentColor}" Opacity="0.3"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF6B6B"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse Fill="{StaticResource AccentColor}" Opacity="0.8"/>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="FontSize" Value="14"/>
            <!-- BorderRadius удален - его нет в стандартном WPF -->
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,8"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF6B6B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для вертикального слайдера -->
        <Style x:Key="VerticalSlider" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Height" Value="120"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Панель кнопок управления плейлистом -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
            <Button Command="{Binding AddFilesCommand}" Content="📂 Добавить"/>
            <Button Command="{Binding RemoveSongCommand}" Content="🗑 Удалить"/>
            <Button Command="{Binding ClearPlaylistCommand}" Content="🧹 Очистить"/>
        </StackPanel>

        <!-- Список песен -->
        <ListBox Grid.Row="1" Grid.Column="0"
                 ItemsSource="{Binding Playlist}" 
                 SelectedItem="{Binding CurrentSong, Mode=TwoWay}"
                 DisplayMemberPath="Name" 
                 Margin="0,10,0,10"/>

        <!-- Информация о текущей песне -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="{Binding CurrentSong.Name, FallbackValue='🎵 Нет выбранной песни'}" 
                   FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,5,0,10"
                   Foreground="White"/>

        <!-- Ползунок прогресса -->
        <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Slider x:Name="ProgressSlider"
                    Value="{Binding CurrentPosition, Mode=TwoWay}" 
                    Width="500" Minimum="0" Maximum="1"
                    PreviewMouseLeftButtonDown="Slider_PreviewMouseDown"
                    PreviewMouseLeftButtonUp="Slider_PreviewMouseUp"/>
            <TextBlock Text="{Binding CurrentSong.Duration, FallbackValue='00:00'}" 
                       Margin="15,0,0,0" FontSize="14" Foreground="#AAAAAA"/>
        </StackPanel>

        <!-- Кнопки управления плеером -->
        <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,5,0,10">
            <Button Style="{StaticResource ControlButton}" 
                    Command="{Binding PreviousCommand}" 
                    Content="⏮"/>

            <Button Style="{StaticResource ControlButton}" 
                    Command="{Binding PlayCommand}" 
                    Content="{Binding IsPlaying, Converter={StaticResource PlayPauseConverter}, FallbackValue='▶️'}"/>

            <Button Style="{StaticResource ControlButton}" 
                    Command="{Binding NextCommand}" 
                    Content="⏭"/>
        </StackPanel>

        <!-- Вертикальная громкость -->
        <StackPanel Grid.Row="0" Grid.RowSpan="5" Grid.Column="1" 
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="20,0,0,0">

            <TextBlock Text="🔊" FontSize="24" Margin="0,0,0,10" 
                       HorizontalAlignment="Center" Foreground="White"/>

            <Slider x:Name="VolumeSlider"
                    Style="{StaticResource VerticalSlider}"
                    Value="{Binding Volume, Mode=TwoWay}"
                    ToolTip="Громкость"
                    TickFrequency="0.1"
                    TickPlacement="Both"/>

            <TextBlock Text="{Binding Volume, StringFormat={}{0:P0}}" 
                       FontSize="14" Foreground="#AAAAAA"
                       Margin="0,10,0,0" HorizontalAlignment="Center"/>

            <Button Command="{Binding MuteCommand}" 
                    Content="🔇" 
                    Background="Transparent" 
                    Foreground="White"
                    FontSize="20"
                    Padding="5"
                    Margin="0,10,0,0"
                    ToolTip="Выключить звук"
                    Width="40" Height="40"/>
        </StackPanel>

        <!-- Скрытый MediaElement -->
        <MediaElement x:Name="Player" 
                      Grid.RowSpan="5"
                      Grid.ColumnSpan="2"
                      LoadedBehavior="Manual"
                      MediaOpened="Player_MediaOpened" 
                      MediaEnded="Player_MediaEnded"
                      MediaFailed="Player_MediaFailed"
                      Visibility="Collapsed"/>
    </Grid>
</Window>